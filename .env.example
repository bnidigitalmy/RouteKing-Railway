# Gemini OCR - kept server-side behind /api/ocr/extract
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash

# Google Maps Geocoding - kept server-side behind /api/geocode
GOOGLE_MAPS_API_KEY=

# ToyyibPay Configuration
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=
TOYYIBPAY_SANDBOX=false

# App URL - used for ToyyibPay return/callback URLs
# For Cloud Run with a custom domain, set PUBLIC_URL to the custom domain.
# APP_URL is the fallback (can be the .run.app URL).
APP_URL=https://app.routeking.my
PUBLIC_URL=https://app.routeking.my

# Allowed domains for CSRF and redirect validation (comma-separated)
ALLOWED_DOMAINS=routeking.my,app.routeking.my,www.routeking.my

# Secret used to sign customer "pin location" links (HMAC). Use a long random
# string, e.g. `openssl rand -hex 32`. If unset, the pin-location feature is
# disabled and the WhatsApp message is sent without a location link.
LOCATION_TOKEN_SECRET=

# Railway only: Firebase Admin service account JSON as a single-line env var.
# Do not commit the real JSON file or value.
FIREBASE_SERVICE_ACCOUNT_JSON=
