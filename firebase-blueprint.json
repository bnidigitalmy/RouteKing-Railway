{
  "entities": {
    "parcel": {
      "title": "Parcel",
      "description": "Information about a parcel to be delivered",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientName": { "type": "string" },
        "address": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "delivered"] },
        "sequenceNumber": { "type": "number" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "scannedAt": { "type": "number" },
        "isCOD": { "type": "boolean" },
        "codAmount": { "type": "number" },
        "groupTag": { "type": "string" },
        "folder": { "type": "string" },
        "uid": { "type": "string", "description": "Owner's user ID" }
      },
      "required": ["id", "address", "trackingNumber", "status", "uid"]
    },
    "folder": {
      "title": "Folder",
      "description": "User created folders for organizing parcels",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "uid": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "uid"]
    },
    "geocache": {
      "title": "GeoCache",
      "description": "Cached coordinates for addresses to save API costs",
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "lastUpdated": { "type": "number" }
      },
      "required": ["address", "lat", "lng"]
    },
    "profile": {
      "title": "UserProfile",
      "description": "User profile and subscription information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "riderName": { "type": "string" },
        "courierCompany": { "type": "string" },
        "isPro": { "type": "boolean" },
        "subscriptionTier": { "type": "string", "enum": ["free", "lite", "standard", "ultimate"] },
        "trialStartedAt": { "type": "number" },
        "expiryDate": { "type": "number" },
        "subscriptionType": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "riderName", "courierCompany"]
    },
    "pending_payment": {
      "title": "PendingPayment",
      "description": "Temporary storage for payment session data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string" },
        "tier": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "object" }
      },
      "required": ["uid", "email", "type", "tier", "amount"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "profile",
      "description": "User profile and subscription data"
    },
    "/pending_payments/{refNo}": {
      "schema": "pending_payment",
      "description": "Payment sessions awaiting callback"
    },
    "/parcels/{parcelId}": {
      "schema": "parcel",
      "description": "Individual parcel documents"
    },
    "/folders/{folderId}": {
      "schema": "folder",
      "description": "User folders"
    },
    "/geocache/{addressHash}": {
      "schema": "geocache",
      "description": "Cached geocoding results"
    },
    "/users/{userId}/verified_addresses/{addressHash}": {
      "schema": "geocache",
      "description": "User-specific verified addresses with notes"
    }
  }
}
