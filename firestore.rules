rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Phase 3: Primitive Definition
    // ===============================================================

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() { 
      return isSignedIn() && 
        (
          (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
          (request.auth.token.email_verified == true && request.auth.token.email == "bnidigital.my@gmail.com")
        );
    }

    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Helper to check if a subscription is active (Trial or Pro)
    function isSubscriptionActive() {
      let profile = get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
      let now = request.time.toMillis();
      let trialDuration = 7 * 24 * 60 * 60 * 1000;
      let trialStartedAt = profile.get('trialStartedAt', 0);
      let trialActive = trialStartedAt > 0 && (now - trialStartedAt) <= trialDuration;
      let subActive = profile.get('isPro', false) == true && profile.get('expiryDate', 0) > now;
      return trialActive || subActive || isAdmin();
    }

    // ===============================================================
    // Entity Validations (Pillar 2)
    // ===============================================================

    function isValidParcel(data) {
      return data.keys().hasAll(['id', 'address', 'trackingNumber', 'status', 'uid']) &&
             data.id is string && data.id.size() <= 64 &&
             data.address is string && data.address.size() <= 1000 &&
             data.trackingNumber is string && data.trackingNumber.size() <= 100 &&
             data.status in ['pending', 'delivered', 'failed', 'retry', 'return'] &&
             data.uid == request.auth.uid &&
             (!('sequenceNumber' in data) || data.sequenceNumber is number) &&
             (!('lat' in data) || data.lat is number) &&
             (!('lng' in data) || data.lng is number) &&
             (!('scannedAt' in data) || data.scannedAt is number) &&
             (!('isCOD' in data) || data.isCOD is bool) &&
             (!('codAmount' in data) || data.codAmount is number) &&
             (!('groupTag' in data) || data.groupTag is string) &&
             (!('folder' in data) || data.folder is string || data.folder == null);
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'uid']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.uid == request.auth.uid &&
             (!('createdAt' in data) || data.createdAt is number);
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'riderName', 'courierCompany']) &&
             data.uid == request.auth.uid &&
             data.riderName is string && data.riderName.size() <= 100 &&
             data.courierCompany is string && data.courierCompany.size() <= 100 &&
             (!('isPro' in data) || data.isPro is bool) &&
             (!('subscriptionTier' in data) || data.subscriptionTier in ['free', 'lite', 'standard', 'ultimate']) &&
             (!('trialStartedAt' in data) || data.trialStartedAt is number) &&
             (!('expiryDate' in data) || data.expiryDate is number || data.expiryDate == null) &&
             (!('subscriptionType' in data) || data.subscriptionType is string || data.subscriptionType == null) &&
             (!('role' in data) || data.role is string) &&
             (!('hasSeenOnboarding' in data) || data.hasSeenOnboarding is bool);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidProfile(incoming()) && 
                    !('isPro' in incoming()) && 
                    !('role' in incoming()) && 
                    !('expiryDate' in incoming()) &&
                    // Trial start validation
                    (!('trialStartedAt' in incoming()) || 
                      (incoming().trialStartedAt >= (request.time.toMillis() - 60000) && 
                       incoming().trialStartedAt <= (request.time.toMillis() + 60000)));

      allow update: if (isOwner(userId) && isValidProfile(incoming()) && (
        // Action: Basic Info update
        (incoming().diff(existing()).affectedKeys().hasOnly(['riderName', 'courierCompany', 'hasSeenOnboarding'])) ||
        // Action: Trial Claim
        (incoming().diff(existing()).affectedKeys().hasOnly(['trialStartedAt']) && 
         existing().get('trialStartedAt', 0) == 0 &&
         incoming().trialStartedAt >= (request.time.toMillis() - 60000))
      )) || isAdmin();
    }

    // Parcels
    match /parcels/{parcelId} {
      allow read: if isSignedIn() && existing().uid == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; // Pillar 8
      
      allow create: if isSignedIn() && isSubscriptionActive() && isValidParcel(incoming()) && isValidId(parcelId);
      
      allow update: if (isSignedIn() && existing().uid == request.auth.uid && isSubscriptionActive() && (
        // Pillar 4 Action-based updates
        // Action: Update Status
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'scannedAt', 'deliveredAt', 'podPhotoUrl', 'failedAt', 'failedReason', 'failedPhotoUrl', 'sequenceNumber'])) ||
        // Action: Reorganize
        (incoming().diff(existing()).affectedKeys().hasOnly(['folder', 'groupTag', 'sequenceNumber'])) ||
        // Action: Edit Data
        (incoming().diff(existing()).affectedKeys().hasOnly(['recipientName', 'address', 'trackingNumber', 'isCOD', 'codAmount', 'lat', 'lng']))
      )) || isAdmin();

      allow delete: if (isSignedIn() && existing().uid == request.auth.uid) || isAdmin();
    }

    // Folders
    match /folders/{folderId} {
      allow read: if isSignedIn() && existing().uid == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isSignedIn() && isSubscriptionActive() && isValidFolder(incoming()) && isValidId(folderId);
      allow update: if (isSignedIn() && existing().uid == request.auth.uid && isValidId(folderId) && isValidFolder(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name'])) || isAdmin();
      allow delete: if (isSignedIn() && existing().uid == request.auth.uid) || isAdmin();
    }

    // Discounts
    match /discounts/{discountId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Geocache (Shared Resource)
    match /geocache/{addressHash} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    incoming().keys().hasAll(['address', 'lat', 'lng']) &&
                    incoming().address is string && incoming().address.size() < 1000 &&
                    incoming().lat is number && incoming().lng is number;
      allow update, delete: if isAdmin();
    }

    // User Private Verified Addresses
    match /users/{userId}/verified_addresses/{addressHash} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Pending Payments (System Only)
    match /pending_payments/{refNo} {
      allow read, write: if isAdmin();
    }
  }
}
