rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitive Definitions
    // ===============================================================

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Admin: role stored in profile document (not hardcoded email)
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Check whether the user's subscription (trial or paid) is active
    function isSubscriptionActive() {
      let profile = get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
      let now = request.time.toMillis();

      // New: scan-based trial — trialScansUsed present and below limit
      let trialScansUsed = profile.get('trialScansUsed', -1);
      let trialEligible = profile.get('isPro', false) != true;
      let scanTrialActive = trialEligible && trialScansUsed >= 0 && trialScansUsed < 50;

      // Legacy: time-based 7-day trial (for users created before scan-based trial)
      let trialDuration = 7 * 24 * 60 * 60 * 1000;
      let trialStartedAt = profile.get('trialStartedAt', 0);
      let legacyTrialActive = trialEligible && trialStartedAt > 0 && (now - trialStartedAt) <= trialDuration;

      let subActive = profile.get('isPro', false) == true && profile.get('expiryDate', 0) > now;
      return scanTrialActive || legacyTrialActive || subActive || isAdmin();
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'uid']) &&
             data.keys().hasOnly(['name', 'uid', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.uid == request.auth.uid &&
             (!('createdAt' in data) || data.createdAt is number);
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'riderName', 'courierCompany']) &&
             data.keys().hasOnly([
               'uid', 'riderName', 'courierCompany', 'email', 'phone',
               'ratePerParcel', 'trialStartedAt', 'dailyScanCount',
               'lastScanResetDate', 'monthlyScanCount', 'lastScanResetMonth',
               'trialScansUsed', 'hasSeenOnboarding', 'isPro',
               'subscriptionTier', 'expiryDate', 'subscriptionType', 'role'
             ]) &&
             data.uid == request.auth.uid &&
             data.riderName is string && data.riderName.size() <= 100 &&
             data.courierCompany is string && data.courierCompany.size() <= 100 &&
             (!('email' in data) || data.email is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('ratePerParcel' in data) || data.ratePerParcel is number) &&
             (!('isPro' in data) || data.isPro is bool) &&
             (!('subscriptionTier' in data) || data.subscriptionTier in ['free', 'lite', 'standard', 'ultimate']) &&
             (!('trialStartedAt' in data) || data.trialStartedAt is number) &&
             (!('dailyScanCount' in data) || data.dailyScanCount is number) &&
             (!('lastScanResetDate' in data) || data.lastScanResetDate is string) &&
             (!('monthlyScanCount' in data) || data.monthlyScanCount is number) &&
             (!('lastScanResetMonth' in data) || data.lastScanResetMonth is string) &&
             (!('trialScansUsed' in data) || data.trialScansUsed is number) &&
             (!('expiryDate' in data) || data.expiryDate is number || data.expiryDate == null) &&
             (!('subscriptionType' in data) || data.subscriptionType is string || data.subscriptionType == null) &&
             (!('role' in data) || data.role is string) &&
             (!('hasSeenOnboarding' in data) || data.hasSeenOnboarding is bool);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Profiles
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Create: owner only; block elevation of privilege fields
      allow create: if isOwner(userId) && isValidProfile(incoming()) &&
                    !('isPro' in incoming()) &&
                    !('role' in incoming()) &&
                    !('expiryDate' in incoming()) &&
                    // trialStartedAt must be within ±60 s of server time if supplied
                    (!('trialStartedAt' in incoming()) ||
                      (incoming().trialStartedAt >= (request.time.toMillis() - 60000) &&
                       incoming().trialStartedAt <= (request.time.toMillis() + 60000)));

      // Update: restrict to safe field subsets
      allow update: if (isOwner(userId) && isValidProfile(incoming()) && (
        // Basic info update (no subscription fields)
        (incoming().diff(existing()).affectedKeys().hasOnly(['riderName', 'courierCompany', 'email', 'phone', 'ratePerParcel', 'hasSeenOnboarding'])) ||
        // Trial claim — only allowed once (existing trialStartedAt must be 0/absent)
        (incoming().diff(existing()).affectedKeys().hasOnly(['trialStartedAt']) &&
         existing().get('trialStartedAt', 0) == 0 &&
         incoming().trialStartedAt >= (request.time.toMillis() - 60000)) ||
        // Scan count update — trialScansUsed can only increment (never decrease)
        (incoming().diff(existing()).affectedKeys().hasOnly(['dailyScanCount', 'lastScanResetDate', 'monthlyScanCount', 'lastScanResetMonth', 'trialScansUsed']) &&
         incoming().get('trialScansUsed', existing().get('trialScansUsed', 0)) >= existing().get('trialScansUsed', 0))
      )) || isAdmin();
      // Subscription fields (isPro, expiryDate, subscriptionTier, etc.) are
      // only writable by the server via the Admin SDK — no client rule permits them.
    }

    // Parcels
    match /parcels/{parcelId} {
      allow read: if isSignedIn() && existing().uid == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;

      // Parcel creation is handled by /api/parcels/create via the Admin SDK so
      // scan counters and trial limits update atomically with the new parcel.
      allow create: if isAdmin();

      allow update: if (isSignedIn() && existing().uid == request.auth.uid &&
                        // Immutability: uid can never change
                        incoming().uid == existing().uid &&
                        isSubscriptionActive() && (
        // Action: Update status / delivery info
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'scannedAt', 'deliveredAt', 'podPhotoUrl', 'failedAt', 'failedReason', 'failedPhotoUrl', 'sequenceNumber'])) ||
        // Action: Reorganize (folder / group)
        (incoming().diff(existing()).affectedKeys().hasOnly(['folder', 'groupTag', 'sequenceNumber'])) ||
        // Action: Edit parcel data
        (incoming().diff(existing()).affectedKeys().hasOnly(['recipientName', 'recipientPhone', 'address', 'trackingNumber', 'isCOD', 'codAmount', 'lat', 'lng', 'addressNotes', 'isLocationVerified']))
      )) || isAdmin();

      allow delete: if (isSignedIn() && existing().uid == request.auth.uid) || isAdmin();
    }

    // Folders
    match /folders/{folderId} {
      allow read: if isSignedIn() && existing().uid == request.auth.uid || isAdmin();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;

      allow create: if isSignedIn() && isSubscriptionActive() && isValidFolder(incoming()) && isValidId(folderId);

      allow update: if (isSignedIn() && existing().uid == request.auth.uid &&
                        // Immutability: uid can never change
                        incoming().uid == existing().uid &&
                        isValidId(folderId) && isValidFolder(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['name'])) || isAdmin();

      allow delete: if (isSignedIn() && existing().uid == request.auth.uid) || isAdmin();
    }

    // Discounts
    match /discounts/{discountId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Geocache (shared, read-heavy resource)
    match /geocache/{addressHash} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Per-user verified addresses
    match /users/{userId}/verified_addresses/{addressHash} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Pending payments — Admin SDK only (no client access)
    match /pending_payments/{refNo} {
      allow read, write: if isAdmin();
    }
  }
}
